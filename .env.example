# SandPro OMP Environment Variables
# Copy this to .env and fill in your values

# Admin email — this user gets auto-promoted to ADMIN role on login
VITE_ADMIN_EMAIL=andrewemmelparttimepro@gmail.com

# Firebase Config (populated automatically by AI Studio, or set manually)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API Key (injected by AI Studio, or set manually)
GEMINI_API_KEY=

# Server-side API key for internal routes (reporting, notifications)
SP_OMP_INTERNAL_KEY=sp-omp-internal-key
